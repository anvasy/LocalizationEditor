<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Separator?>

<BorderPane prefHeight="750.0"
            prefWidth="1200.0"
            xmlns:fx="http://fxml.com/fxml/1"
            fx:controller="com.anvasy.ui.controller.EditorController"
            stylesheets="@../../css/styles.css">

    <top>
        <HBox fx:id="titleBar"
              alignment="CENTER_LEFT"
              styleClass="title-bar">

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="—"
                    onAction="#minimizeWindow"
                    styleClass="window-close-button"/>

            <Button text="✕"
                    onAction="#closeWindow"
                    styleClass="window-close-button"/>

        </HBox>
    </top>

    <left>
        <VBox alignment="TOP_CENTER" spacing="15.0" prefWidth="60.0">

            <Button fx:id="btnToggleSidebar"
                    text="☰"
                    onAction="#onToggleSidebarPressed"
                    styleClass="window-close-button"/>

            <Separator/>

            <Button text="📁" styleClass="window-close-button"/>
            <Button text="🔍" styleClass="window-close-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="⚙" styleClass="window-close-button"/>
        </VBox>
    </left>

    <center>
        <SplitPane fx:id="mainSplitPane" dividerPositions="0.22">
            <fx:include fx:id="sideBar" source="../panels/SideBar.fxml"/>
            <HBox fx:id="editorTable"/>
        </SplitPane>
    </center>
</BorderPane>