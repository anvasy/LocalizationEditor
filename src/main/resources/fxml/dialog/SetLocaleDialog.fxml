<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.anvasy.ui.controller.dialog.SetLocaleDialogController"
      spacing="20"
      prefWidth="420"
      styleClass="card">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <VBox spacing="6">
        <Label text="Select Locale"
               styleClass="dialog-title"/>

        <Label text="Unable to automatically detect locale from file name. Please select manually."
               styleClass="dialog-subtitle"
               wrapText="true"/>
    </VBox>


    <VBox spacing="8">
        <Label text="Locale"
               styleClass="grid-text"/>
        <ComboBox fx:id="localeComboBox"
                  maxWidth="Infinity"
                  visibleRowCount="7"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="10"
          alignment="CENTER_RIGHT">

        <Button text="Add"
                onAction="#addLocale"
                styleClass="primary-button"/>

        <Button text="Cancel"
                onAction="#cancel"
                styleClass="button"/>
    </HBox>

</VBox>