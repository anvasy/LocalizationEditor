<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Button?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.anvasy.ui.controller.MainPanelController"
      alignment="TOP_CENTER" spacing="20">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox styleClass="card">
        <GridPane hgap="20" vgap="30">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>

            <columnConstraints>
                <ColumnConstraints percentWidth="70"/>
                <ColumnConstraints percentWidth="30"/>
            </columnConstraints>

            <VBox GridPane.rowIndex="0"
                  GridPane.columnIndex="0">
                <Label text="New Project"
                       styleClass="grid-text"/>
                <Label text="Create a new project"
                       styleClass="grid-text-sub"/>
            </VBox>

            <Button text="Create"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="1"
                    styleClass="primary-button"
                    onAction="#showCreateProject"/>

            <Separator GridPane.rowIndex="1"
                       GridPane.columnSpan="2"/>

            <VBox GridPane.rowIndex="2"
                  GridPane.columnIndex="0">
                <Label text="Open Project"
                       styleClass="grid-text"/>
                <Label text="Choose a project-settings.json to open an existing project."
                       styleClass="grid-text-sub"/>
            </VBox>

            <Button text="Browse"
                    GridPane.rowIndex="2"
                    GridPane.columnIndex="1"
                    styleClass="secondary-button"
                    onAction="#openProject"/>

        </GridPane>
    </VBox>

    <VBox spacing="10">
<!--        <padding>-->
<!--            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>-->
<!--        </padding>-->
        <Label text="Recent Projects:"/>
        <ListView fx:id="recentProjects" prefHeight="300"
                  onMouseClicked="#openRecentProject"/>
    </VBox>

</VBox>
