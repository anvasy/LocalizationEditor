<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER_LEFT"
      spacing="20"
      styleClass="main-content">

    <Label text="No locale files in this project"
           styleClass="empty-title"/>

    <Label text="Create or import your first locale to begin editing."
           styleClass="empty-subtitle"/>

    <Button text="+ Add Locale"
            fx:id="createLocaleButton"/>

</HBox>